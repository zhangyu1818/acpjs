{
  "name": "@acpjs/react",
  "version": "0.2.1",
  "description": "acpjs React hooks and Provider over @acpjs/client (headless, no UI).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyu1818/acpjs.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@acpjs/client": "workspace:*",
    "@acpjs/protocol": "workspace:*",
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@acpjs/core": "workspace:*",
    "@acpjs/fixture-agent": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.0",
    "@types/use-sync-external-store": "^1.5.0",
    "jsdom": "^28.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "engines": {
    "node": ">=24"
  }
}
